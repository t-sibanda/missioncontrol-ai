# ─── Kimi OAuth ──────────────────────────────────────────────────
APP_ID=your-app-id
APP_SECRET=your-app-secret
VITE_APP_ID=your-app-id
VITE_KIMI_AUTH_URL=https://auth.kimi.com
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com
OWNER_UNION_ID=your-owner-union-id

# ─── Database (Supabase PostgreSQL) ──────────────────────────────
# Get this from Supabase Dashboard → Project Settings → Database → Connection string
# Use the pooler connection (port 6543) for serverless environments
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@db.xxxxxxxxxx.supabase.co:6543/postgres

# ─── Frontend / Deployment ───────────────────────────────────────
# Your Cloudflare Pages URL (for CORS)
FRONTEND_URL=https://missioncontrol.pages.dev

# ─── Supabase (optional, for storage) ────────────────────────────
SUPABASE_URL=https://xxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# ─── AI Provider: Groq (free, globally available) ────────────────
# Sign up free at https://console.groq.com → API Keys → Create
# No credit card required. This is the primary AI provider.
GROQ_API_KEY=gsk_your-groq-api-key-here
